# Example environment file. Copy to .env and fill in. .env is gitignored.
#
# In practice the orchestrator reads from the Renaissance parent-dir .env
# and .env.instantly as well — see core/config.py:ENV_FILE_CANDIDATES.
# This file exists only to document the keys.

# Override the DuckDB path (default: /root/core/core.duckdb)
# CORE_DB_PATH=./core.duckdb

# Backup destination
# CORE_BACKUP_DIR=/root/archive/mac-offload/core

# Pipeline-supabase (analytics warehouse)
PIPELINE_SUPABASE_URL=
PIPELINE_SUPABASE_SERVICE_ROLE_KEY=
PIPELINE_SUPABASE_DB_URL=  # full postgresql:// for psycopg2

# Comms-orchestration (Sendivo + warm-call + GBC)
COMMS_SUPABASE_URL=
COMMS_SUPABASE_SERVICE_ROLE_KEY=
COMMS_SUPABASE_DB_URL=

# Outreachify deliverability
OUTREACHIFY_SUPABASE_URL=
OUTREACHIFY_SUPABASE_SERVICE_ROLE_KEY=

# Instantly — per-workspace keys
# Format: INSTANTLY_KEY_<WORKSPACE_SLUG_UPPER_SNAKE>=...
# Excluded from instantly_workspace_keys(): PERSONAL, SAM_TEST, WARM_LEADS
# INSTANTLY_KEY_RENAISSANCE_4=
# INSTANTLY_KEY_KOI_AND_DESTROY=
# ...

# Slack alert webhook for orchestrator failures (optional)
# CORE_SLACK_WEBHOOK_URL=

# Slack QA / backfill alerts (chat.postMessage). Channel id; alerts skip if unset.
# SLACK_TOKEN=
# SLACK_COOKIE=
# SLACK_ALERT_CHANNEL=

# Close CRM (warm-call ingest). API key + account-specific custom-field ids.
# CLOSE_API_KEY=
# CLOSE_CF_CAMPAIGN=
# CLOSE_CF_SOURCE=

# Lead DB (enriched-phone sidecar backfill)
# LEADS_DB_URL=  # full postgresql:// for psycopg2

# Registrar APIs (Track I purchased_at + expires_at backfill, all three registrars,
# every account). backfill_purchased_at_registrars.py iterates the numbered slots.
# Porkbun (default + numbered): POST JSON apikey/secretapikey -> createDate/expireDate
# PORKBUN_API_KEY= / PORKBUN_SECRET_API_KEY=        (default account)
# PORKBUN_<n>_API_KEY= / PORKBUN_<n>_SECRET_API_KEY=  (n = 1..N)
# Spaceship: X-Api-Key/X-Api-Secret headers -> registrationDate/expirationDate
# SPACESHIP_<n>_API_KEY= / SPACESHIP_<n>_API_SECRET=  (n = 1..N)
# Dynadot: key in query (command=list_domain) -> Registration/Expiration (epoch ms)
# DYNADOT_<n>_API_KEY=  (n = 1..N)
# Legacy aliases for the default Porkbun account (scrubbed-repo names, still honored):
# VENDOR_B_LISTALL_URL=  / VENDOR_B_API_KEY=  / VENDOR_B_SECRET_KEY=

# Cloudflare D1 publish (campaign data + CC mirror)
# CC_D1_API_TOKEN=
# D1_ACCOUNT_ID=
# D1_DATABASE_ID=

# Bookings-portal im_bookings nightly mirror (entities/im_bookings.py, Scope A 2026-06-09).
# Publishable (anon-role, RLS-gated) key — read-only PostgREST paging.
# IM_BOOKINGS_SUPABASE_URL=
# IM_BOOKINGS_SUPABASE_ANON_KEY=
